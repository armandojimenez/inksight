# Server
PORT=3000                                    # Server port
NODE_ENV=development                         # Environment mode
ALLOWED_ORIGIN=http://localhost:3000         # CORS allowed origin

# Database
POSTGRES_USER=inksight                       # PostgreSQL username (used by Docker)
POSTGRES_PASSWORD=inksight_dev               # PostgreSQL password (used by Docker)
POSTGRES_DB=inksight                         # PostgreSQL database name (used by Docker)
DATABASE_URL=postgres://inksight:inksight_dev@localhost:5432/inksight

# Upload
UPLOAD_DIR=uploads                           # Directory for stored images
MAX_FILE_SIZE=16777216                       # Max upload size in bytes (16 MB)

# Rate Limiting
RATE_LIMIT_TTL=60000                         # Rate limit window in ms (1 min)
RATE_LIMIT_MAX=100                           # Max requests per window

# SSE
MAX_SSE_PER_IP=5                             # Max concurrent SSE connections per IP

# Scheduled Cleanup
CLEANUP_ENABLED=true                         # Enable/disable scheduled cleanup
CLEANUP_IMAGE_TTL_MS=86400000                # Image expiration in ms (24h)
CLEANUP_TEMP_TTL_MS=3600000                  # Temp file expiration in ms (1h)
