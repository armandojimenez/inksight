{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenAI Chat Completion Stream Chunk",
  "description": "Validates streaming chat completion chunks per the OpenAI SSE protocol. Known limitation: this schema cannot enforce that 'role' only appears in the first chunk — that positional constraint is verified in test assertions.",
  "type": "object",
  "required": ["id", "object", "created", "model", "choices"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^chatcmpl-[a-zA-Z0-9]{29}$"
    },
    "object": {
      "type": "string",
      "const": "chat.completion.chunk"
    },
    "created": {
      "type": "integer",
      "minimum": 0
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "choices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["index", "delta", "finish_reason"],
        "additionalProperties": false,
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 0
          },
          "delta": {
            "type": "object",
            "minProperties": 0,
            "additionalProperties": false,
            "properties": {
              "role": {
                "type": "string",
                "const": "assistant"
              },
              "content": {
                "type": "string"
              }
            }
          },
          "finish_reason": {
            "type": ["string", "null"],
            "enum": ["stop", null]
          }
        }
      }
    }
  }
}
